// Prisma schema voor Huishoudboekje (multi-tenant).
// Elk huishouden (Household) is een aparte tenant; alle data hangt aan een
// householdId. Database: PostgreSQL (lokaal én op Vercel) via DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Directe (unpooled) Neon-verbinding voor zowel runtime als migraties — geen
  // pgbouncer-gedoe. Prima voor deze schaal; later evt. pooled voor runtime.
  url      = env("DATABASE_URL_UNPOOLED")
}

model Household {
  id                  Int      @id @default(autoincrement())
  name                String
  tier                String   @default("basis") // basis | plus | compleet
  coParentHouseholdId Int? // gekoppeld co-ouder-huishouden (gescheiden ouders)
  inboundToken        String?  @unique // gezinsmail: lokaal deel van het inbound-adres
  createdAt           DateTime @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  householdId  Int
  role         String   @default("member") // owner | member | child
  memberId     Int? // gekoppeld FamilyMember (welk gezinslid is deze login)
  termsAcceptedAt DateTime? // moment van akkoord met voorwaarden + privacybeleid
  // Profielgegevens die de gebruiker zelf beheert.
  avatarUrl        String? // profielfoto (data-URL of externe URL)
  nickname         String? // roepnaam
  phone            String?
  address          String?
  birthday         String? // geboortedatum (yyyy-mm-dd of vrije tekst)
  emergencyContact String? // noodcontact (naam + telefoon)
  createdAt        DateTime @default(now())

  @@index([householdId])
}

model FamilyMember {
  id          Int      @id @default(autoincrement())
  householdId Int
  name        String
  initials    String
  color       String
  role        String?
  birthday    String?
  isChild     Boolean  @default(false)
  // Medische gegevens (bijzondere persoonsgegevens) — alleen binnen het gezin.
  bloodType    String?
  allergies    String?
  medication   String?
  medicalNotes String?
  createdAt   DateTime @default(now())

  @@index([householdId])
}

model AgendaEvent {
  id          Int      @id @default(autoincrement())
  householdId Int
  dateKey     String
  day         String
  month       String
  weekday     String
  title       String
  time        String
  who         String
  accent      String   @default("sky")
  // "manual" (in de app gemaakt) of "ical" (gesynct uit een agenda/Parro-feed)
  source      String   @default("manual")
  externalId  String?
  coShared    Boolean  @default(false) // gedeeld met het co-ouder-huishouden
  remindDays  Int? // null = geen reminder; 0 = op de dag, 1 = dag ervoor, etc.
  createdAt   DateTime @default(now())

  @@unique([householdId, externalId])
  @@index([householdId])
}

model ShoppingItem {
  id          Int      @id @default(autoincrement())
  householdId Int
  label       String
  checked     Boolean  @default(false)
  category    String   @default("Overig")
  qty         String?
  createdAt   DateTime @default(now())

  @@index([householdId])
}

model Recipe {
  id          Int      @id @default(autoincrement())
  householdId Int
  title       String
  image       String
  time        String
  servings    String
  // komma-gescheiden tags (SQLite-vriendelijk; wordt Json bij Postgres-migratie)
  tags        String   @default("")
  description String
  // Json-arrays: ingredients = [{ name, amount }], steps = [string]
  ingredients Json?
  steps       Json?
  favorite    Boolean  @default(false)
  // -1 = duim omlaag, 0 = neutraal, 1 = duim omhoog (voor aanbevelingen)
  vote        Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([householdId])
}

model BudgetCategory {
  id          Int    @id @default(autoincrement())
  householdId Int
  name        String
  // lucide-iconnaam, in de UI teruggemapt naar het component
  icon        String @default("ShoppingCart")
  spent       Float  @default(0)
  limit       Float  @default(0)
  color       String @default("emerald")

  @@index([householdId])
}

model Transaction {
  id            Int      @id @default(autoincrement())
  householdId   Int
  label         String
  category      String
  amount        Float
  date          String
  note          String? // eigen notitie bij de uitgave
  paymentMethod String? // pin | creditcard | contant | incasso | overboeking
  createdAt     DateTime @default(now())

  @@index([householdId])
}

model ChatMessage {
  id          Int      @id @default(autoincrement())
  householdId Int
  role        String // "assistant" | "user"
  text        String
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Vrije sleutel/waarde-config per huishouden, bewerkbaar via Instellingen.
model Setting {
  id          Int    @id @default(autoincrement())
  householdId Int
  key         String
  value       String

  @@unique([householdId, key])
}

// Eén record per koppeling per huishouden (weather | ical | ai | mollie | supermarkt).
model Integration {
  id          Int      @id @default(autoincrement())
  householdId Int
  key         String
  name        String
  status      String   @default("disconnected") // connected | disconnected | coming_soon
  config      String   @default("{}") // JSON-tekst
  updatedAt   DateTime @updatedAt

  @@unique([householdId, key])
}

model Subscription {
  id                   Int      @id @default(autoincrement())
  householdId          Int
  name                 String
  amount               Float
  interval             String // bijv. "1 month"
  status               String   @default("pending") // pending | active | canceled
  mollieCustomerId     String?
  mollieSubscriptionId String?
  createdAt            DateTime @default(now())

  @@index([householdId])
}

model Notification {
  id           Int      @id @default(autoincrement())
  householdId  Int
  type         String   @default("system") // stock | agenda | budget | ai | system
  title        String
  body         String?
  read         Boolean  @default(false)
  targetMember String? // gericht aan één gezinslid (naam); null = hele gezin
  createdAt    DateTime @default(now())

  @@index([householdId])
}

model SavingsGoal {
  id          Int      @id @default(autoincrement())
  householdId Int
  name        String
  target      Float
  saved       Float    @default(0)
  targetDate  String? // yyyy-mm-dd, optionele einddatum (voor "maandelijks benodigd")
  theme       String? // cover-thema: algemeen/vakantie/auto/huis/feest/noodfonds
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Gezinsbudget-"potjes" (envelopes): een maandbudget per onderwerp, optioneel
// toegewezen aan een gezinslid. 'spent' wordt handmatig bijgehouden (uitgave loggen).
model FamilyBudget {
  id          Int      @id @default(autoincrement())
  householdId Int
  name        String
  limit       Float    @default(0)
  spent       Float    @default(0)
  member      String? // naam van het gezinslid (optioneel)
  color       String   @default("emerald")
  createdAt   DateTime @default(now())

  @@index([householdId])
}

model FixedCost {
  id          Int      @id @default(autoincrement())
  householdId Int
  name        String
  amount      Float
  category    String   @default("Overig") // Wonen | Energie | Verzekering | Telecom ...
  // dag van de maand waarop het wordt afgeschreven (optioneel)
  dueDay      Int?
  // Abonnement-markering: een vaste last kan ook een abonnement zijn.
  isSubscription         Boolean   @default(false)
  subscriptionInterval   String?   // "1 month" | "12 months"
  subscriptionCancelable Boolean   @default(true) // maandelijks opzegbaar
  subscriptionEndDate    String? // einddatum yyyy-mm-dd (null = doorlopend)
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Inkomsten van het huishouden (loon, toeslagen, uitkeringen, alimentatie...).
model Income {
  id          Int      @id @default(autoincrement())
  householdId Int
  label       String // "Loon Sanne", "Kinderbijslag", "Zorgtoeslag"
  amount      Float
  category    String   @default("loon") // loon | toeslag | uitkering | overig
  interval    String   @default("1 month") // 1 month | 12 months (voor jaarlijkse posten)
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Geleerde categorisatie-regels: onthoudt hoe een winkel/omschrijving ingedeeld
// wordt. Toegepast bij import én op bestaande transacties (Overig opschonen).
model MerchantRule {
  id          Int      @id @default(autoincrement())
  householdId Int
  pattern     String // genormaliseerd trefwoord (substring-match op de omschrijving)
  category    String   @default("") // doelcategorie bij kind=expense
  kind        String   @default("expense") // expense | income | fixed | ignore
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Leningen/hypotheek met restschuld. Aflossings-transacties worden via
// matchPattern (trefwoord op de omschrijving) automatisch gekoppeld: de som
// daarvan + manualPaid bepaalt hoeveel er al is afgelost.
model Loan {
  id           Int      @id @default(autoincrement())
  householdId  Int
  name         String // "Lening Boots Holding", "Hypotheek"
  lender       String? // geldverstrekker
  total        Float    @default(0) // totaal af te lossen (oorspronkelijke schuld)
  termAmount   Float? // maandtermijn (optioneel)
  matchPattern String? // trefwoord om aflossings-transacties te koppelen
  excludePattern String? // trefwoord dat een match juist uitsluit (bv. "premie")
  manualPaid   Float    @default(0) // extra handmatig afgelost (buiten transacties)
  startDate    String? // yyyy-mm-dd
  createdAt    DateTime @default(now())

  @@index([householdId])
}

// Gedeelde klantenkaarten/pasjes (premium). Gedeeld binnen het huishouden via
// householdId. Foto (imageUrl) en/of barcode-nummer (code).
model Card {
  id          Int      @id @default(autoincrement())
  householdId Int
  name        String // "Bibliotheek", "Kruidvat"
  code        String? // barcode-/pasnummer
  format      String   @default("CODE128")
  imageUrl    String? // foto van het pasje (data-URL of externe URL)
  color       String   @default("from-sky-400 to-blue-500")
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Web-push-abonnementen per gebruiker (voor echte pushmeldingen).
model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Gezinsspel: taken toegewezen aan een gezinslid, met punten en status.
model Task {
  id          Int      @id @default(autoincrement())
  householdId Int
  title       String
  description String?
  assignedTo  String? // gezinslid-naam (null = hele gezin)
  points      Int      @default(0)
  status      String   @default("todo") // open (wacht op accept) | todo | klaar | geweigerd
  dueDate     String? // yyyy-mm-dd
  // geen | dagelijks | wekelijks | maandelijks — bij afronden wordt een nieuwe gemaakt
  recurrence  String   @default("geen")
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Ingewisselde beloningen (punten eraf) per gezinslid.
model Redemption {
  id          Int      @id @default(autoincrement())
  householdId Int
  member      String
  title       String
  cost        Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Belangrijke contacten/adressen (school, opvang, dokter, oma...) per huishouden.
model Contact {
  id          Int      @id @default(autoincrement())
  householdId Int
  name        String // "School De Regenboog", "Oma", "Tandarts"
  category    String   @default("overig") // school | opvang | zorg | familie | overig
  phone       String?
  address     String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Eigen beloningen van het gezin (household-scoped), naast de partner-catalogus.
model FamilyReward {
  id          Int      @id @default(autoincrement())
  householdId Int
  title       String // "30 min extra schermtijd"
  description String?
  cost        Int      @default(0) // punten/taken nodig
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Documenten/bewijzen: garantiebewijzen en legitimatie (paspoort/rijbewijs) met
// optionele verloopdatum voor reminders. Gedeeld binnen het huishouden.
model Document {
  id          Int      @id @default(autoincrement())
  householdId Int
  title       String // "Wasmachine garantie", "Paspoort Sanne"
  type        String   @default("garantie") // garantie | legitimatie | overig
  owner       String? // van wie (bv. gezinslid)
  imageUrl    String? // foto van het bewijs/document
  expiresAt   String? // verloopdatum yyyy-mm-dd
  notes       String?
  createdAt   DateTime @default(now())

  @@index([householdId])
}

// Idempotentie voor de dagelijkse reminder-cron: per (huishouden, key) wordt een
// reminder maar één keer verstuurd. De key codeert de bron + drempel + jaar,
// bijv. "occ:Vaderdag:2026:b10", "bday:7:2026:b7", "doc:12:2026-12-01:b30",
// "agenda:45:2026-06-15". Zo verliest een gemiste cron-dag de reminder niet en
// ontstaat er geen dagelijkse spam.
model ReminderLog {
  id          Int      @id @default(autoincrement())
  householdId Int
  key         String
  createdAt   DateTime @default(now())

  @@unique([householdId, key])
  @@index([householdId])
}

// Uit een iCal-feed verwijderde afspraken: onthoud de externalId zodat de sync
// ze niet opnieuw toevoegt. Atomair (unieke index) i.p.v. een JSON-lijst, zodat
// gelijktijdige verwijderingen elkaar niet overschrijven.
model HiddenIcalEvent {
  id          Int      @id @default(autoincrement())
  householdId Int
  externalId  String
  createdAt   DateTime @default(now())

  @@unique([householdId, externalId])
  @@index([householdId])
}

// Gezinsmail (premium): doorgestuurde mails (facturen, garanties, afspraken) die
// via Resend Inbound binnenkomen, door de AI worden geclassificeerd en automatisch
// op de juiste plek worden gezet. Eén record per ontvangen mail = de inbox.
model MailItem {
  id             Int      @id @default(autoincrement())
  householdId    Int
  emailId        String? // Resend email_id (voor ophalen body/bijlagen)
  fromAddr       String
  fromName       String?
  subject        String
  snippet        String? // korte preview van de inhoud
  status         String   @default("nieuw") // nieuw | verwerkt | genegeerd
  category       String? // garantie | document | afspraak | boodschap | overig
  summary        String? // AI-samenvatting: wat is dit / wat is gedaan
  filedType      String? // document | agenda | shopping | null
  filedId        Int? // id van het automatisch gemaakte record
  attachmentUrl  String? // download-URL van de (eerste) bijlage
  attachmentName String? // bestandsnaam van de bijlage
  createdAt      DateTime @default(now())

  @@index([householdId])
}

// Platform-brede advertenties/aanbiedingen (bv. AH-bonus-uitjes), beheerd door admin.
model Ad {
  id        Int      @id @default(autoincrement())
  sponsor   String
  title     String
  body      String?
  imageUrl  String?
  linkUrl   String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

// Platform-brede, adverteerder-gesponsorde beloningen voor het gezinsspel.
// GEEN householdId: dit is een globale catalogus, beheerd in /beheer en
// zichtbaar voor alle gezinnen. Koppelt later aan een Task (veld rewardId).
model Reward {
  id          Int      @id @default(autoincrement())
  partner     String // adverteerder, bv. "Efteling"
  title       String // "Dagje Efteling"
  description String
  imageUrl    String?
  conditions  String? // voorwaarden, bv. "Mits 20 taken volbracht"
  category    String   @default("uitje") // uitje | product | tegoed | ervaring
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}
