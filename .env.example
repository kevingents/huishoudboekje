# Kopieer dit naar .env (lokaal) en vul je waarden in. In Vercel zet je deze
# als Environment Variables. .env staat in .gitignore (geen secrets in git).

# PostgreSQL (verplicht). DATABASE_URL = pooled verbinding (runtime),
# DATABASE_URL_UNPOOLED = directe verbinding (voor migraties).
# Neon zet beide automatisch in Vercel. Niet-Neon/lokaal: zet ze gelijk.
DATABASE_URL="postgresql://user:password@host:5432/huishoudboekje?schema=public"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/huishoudboekje?schema=public"

# Geheim voor het ondertekenen van de inlog-sessie (verplicht in productie).
# Genereer bv. met: openssl rand -base64 32
AUTH_SECRET=

# AI Assistent — Claude (Anthropic). Zonder key valt de chat/recepten/koelkast
# terug op een nette melding. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Mollie — pakketten/betalen. Een test-key (test_...) volstaat om te testen.
# Naam moet MOLLIE_API_KEY zijn (MOLLIE_TEST_API_KEY / MOLLIE_TEST_API werken ook).
MOLLIE_API_KEY=

# E-mail via Resend (welkomst-, uitnodigings- en wachtwoord-herstelmail).
# Zonder key: alleen gelogd. LET OP: onboarding@resend.dev mailt alleen naar je
# eigen account-adres — verifieer een eigen domein + zet RESEND_FROM om naar
# anderen te kunnen mailen.
RESEND_API_KEY=
RESEND_FROM=Fam <onboarding@resend.dev>

# Platformbeheerders (komma-gescheiden e-mailadressen) die /beheer mogen zien.
ADMIN_EMAILS=

# Echte pushmeldingen (web-push). Genereer een sleutelpaar met:
#   npx web-push generate-vapid-keys
# De publieke sleutel mag publiek (NEXT_PUBLIC_), de private is geheim.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@fam.app

# Cron-beveiliging (verloop-reminders /api/cron/expiry).
CRON_SECRET=

# Publieke basis-URL (voor Mollie redirect/webhook), bv. je Vercel-URL.
NEXT_PUBLIC_BASE_URL=
