# Kopieer dit naar .env.local en vul in wat je wilt gebruiken.
# .env.local staat in .gitignore (secrets komen niet in git).

# Geheim voor het ondertekenen van de inlog-sessie. Zet een lange,
# willekeurige waarde in productie (bijv. `openssl rand -base64 32`).
AUTH_SECRET=

# AI Assistent — Claude (Anthropic). Zonder key valt de chat terug op een
# vast voorbeeldantwoord. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Mollie — abonnementen/betalen. Een test-key (test_...) volstaat om te testen.
# https://my.mollie.com/dashboard/developers/api-keys
MOLLIE_API_KEY=

# Publieke basis-URL van de app (voor Mollie redirect/webhook), bijv.
# http://localhost:3000 in dev of je Vercel-URL in productie.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
